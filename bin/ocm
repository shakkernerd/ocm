#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export CARGO_HOME="${CARGO_HOME:-/tmp/ocm-cargo-home}"
# Keep the wrapper on its own default build dir so nested `cargo run` flows
# do not contend with an outer `cargo test`/`cargo build` holding the main
# artifact lock for `$ROOT_DIR/target`.
export CARGO_TARGET_DIR="${CARGO_TARGET_DIR:-$ROOT_DIR/target/bin-ocm}"
export OCM_SELF="${OCM_SELF:-$0}"

if [[ -z "${RUSTUP_HOME:-}" ]]; then
  CARGO_BIN="$(command -v cargo || true)"
  if [[ -n "$CARGO_BIN" && "$CARGO_BIN" == */.cargo/bin/cargo ]]; then
    export RUSTUP_HOME="${CARGO_BIN%/.cargo/bin/cargo}/.rustup"
  fi
fi

exec cargo run --quiet --manifest-path "$ROOT_DIR/Cargo.toml" -- "$@"
